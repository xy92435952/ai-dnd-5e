# ── LLM（OpenAI 兼容 API）──────────────────────────────
# 支持 AiHubMix / OpenRouter / OpenAI 等任意 OpenAI 兼容 API
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://aihubmix.com/v1
LLM_MODEL=claude-sonnet-4-6

# 也可以切换到 DeepSeek 这类 OpenAI 兼容服务：
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash

# ── ChromaDB（本地 RAG 向量库）─────────────────────────
CHROMADB_PATH=./chromadb_data

# ── LangGraph 对话记忆 ────────────────────────────────
LANGGRAPH_DB_PATH=./langgraph_memory.db
# 生产服务器已迁移 PostgreSQL；生产环境必须设置 LANGGRAPH_DB_URL。
# 本地开发留空则使用上面的 SQLite 文件。
LANGGRAPH_DB_URL=

# ── 数据库 ──────────────────────────────────────────────
# 本地开发用 SQLite:
DATABASE_URL=sqlite+aiosqlite:///./ai_trpg.db
# 生产环境用 PostgreSQL，服务器当前已按该路线完成迁移:
# DATABASE_URL=postgresql+asyncpg://ai_trpg:your_password@localhost:5432/ai_trpg
# LANGGRAPH_DB_URL=postgresql://ai_trpg:your_password@localhost:5432/ai_trpg

# ── 文件上传 ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# ── 50 人封闭内测保护阈值（生产单后端实例）──────────────
BETA_MAX_USERS=50
BETA_MAX_WS_CONNECTIONS=80
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_GAME_PER_MINUTE=30
MODULE_PARSE_MAX_CONCURRENT=1
MODULE_PARSE_MAX_BACKLOG=5

# ── 生产安全配置 ───────────────────────────────────────
JWT_SECRET=dev-secret-change-me-at-least-32-bytes
ENV=development
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
