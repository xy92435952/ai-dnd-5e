# ── LLM（OpenAI 兼容 API）──────────────────────────────
# 支持 AiHubMix / OpenRouter / OpenAI 等任意 OpenAI 兼容 API
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://aihubmix.com/v1
LLM_MODEL=claude-sonnet-4-6

# ── ChromaDB（本地 RAG 向量库）─────────────────────────
CHROMADB_PATH=./chromadb_data

# ── LangGraph 对话记忆 ────────────────────────────────
LANGGRAPH_DB_PATH=./langgraph_memory.db
# 生产环境使用 PostgreSQL（设置后自动切换，留空则用上面的 SQLite）
LANGGRAPH_DB_URL=

# ── 数据库 ──────────────────────────────────────────────
# 本地开发用 SQLite:
DATABASE_URL=sqlite+aiosqlite:///./ai_trpg.db
# 生产环境用 PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://ai_trpg:your_password@localhost:5432/ai_trpg

# ── 文件上传 ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
